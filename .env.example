# Database
DATABASE_URL=postgresql://trustops:trustops@localhost:5434/trustops

# Auth
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# OpenAI (optional - mock AI used when not set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# CORS (comma-separated; include all frontend dev ports)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Integration keys
WEBHOOK_API_KEY=dev-webhook-key-change-in-production
SENTINEL_API_KEY=

# Deployment
APP_VERSION=0.2.0-pilot
DEPLOYMENT_MODE=local-demo

# Frontend (use 8001 if 8000 is already in use)
NEXT_PUBLIC_API_URL=http://localhost:8001
